+        LC_ASSERT(tagLength == 0);
+
+        if (!ctx->initialized) {
+            // Create CBC decryptor without padding (matches OpenSSL behavior when
+            // caller uses CIPHER_FLAG_FINISH to strip PKCS7 manually)
+            CCCryptorStatus status = CCCryptorCreateWithMode(
+                kCCDecrypt, kCCModeCBC, kCCAlgorithmAES,
+                ccNoPadding, iv, key, (size_t)keyLength,
+                NULL, 0, 0, 0, &ctx->cbcCryptor);
+            if (status != kCCSuccess) {
+                return false;
+            }
+            memcpy(ctx->key, key, keyLength);
+            ctx->keyLength = keyLength;
+            ctx->initialized = true;
+        }
+        else if (flags & CIPHER_FLAG_RESET_IV) {
+            CCCryptorReset(ctx->cbcCryptor, iv);
+        }
+
+        size_t moved = 0;
+        CCCryptorStatus status = CCCryptorUpdate(ctx->cbcCryptor,
+            inputData, (size_t)inputDataLength,
+            outputData, (size_t)inputDataLength, &moved);
+        if (status != kCCSuccess) {
+            return false;
+        }
+        *outputDataLength = (int)moved;
+
+        if (flags & CIPHER_FLAG_FINISH) {
+            size_t finalMoved = 0;
+            status = CCCryptorFinal(ctx->cbcCryptor,
+                &outputData[*outputDataLength], 16, &finalMoved);
