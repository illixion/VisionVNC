@@ -136,6 +158,84 @@ bool PltEncryptMessage(PPLT_CRYPTO_CONTEXT ctx, int algorithm, int flags,
 
     *outputDataLength = outLength;
     return true;
+#elif defined(USE_COMMONCRYPTO)
