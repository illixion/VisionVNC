+        LC_ASSERT(tagLength == 0);
+
+        if (!ctx->initialized) {
+            // Create CBC encryptor without padding (caller handles PKCS7)
+            CCCryptorStatus status = CCCryptorCreateWithMode(
+                kCCEncrypt, kCCModeCBC, kCCAlgorithmAES,
+                ccNoPadding, iv, key, (size_t)keyLength,
+                NULL, 0, 0, 0, &ctx->cbcCryptor);
+            if (status != kCCSuccess) {
+                return false;
+            }
+            memcpy(ctx->key, key, keyLength);
+            ctx->keyLength = keyLength;
+            ctx->initialized = true;
+        }
+        else if (flags & CIPHER_FLAG_RESET_IV) {
+            CCCryptorReset(ctx->cbcCryptor, iv);
+        }
+
+        if (flags & CIPHER_FLAG_PAD_TO_BLOCK_SIZE) {
+            inputDataLength = addPkcs7PaddingInPlace(inputData, inputDataLength);
+        }
+
+        size_t moved = 0;
+        CCCryptorStatus status = CCCryptorUpdate(ctx->cbcCryptor,
+            inputData, (size_t)inputDataLength,
+            outputData, (size_t)inputDataLength, &moved);
+        if (status != kCCSuccess) {
+            return false;
+        }
+        *outputDataLength = (int)moved;
+
+        if (flags & CIPHER_FLAG_FINISH) {
+            size_t finalMoved = 0;
+            status = CCCryptorFinal(ctx->cbcCryptor,
+                &outputData[*outputDataLength], 16, &finalMoved);
+            if (status != kCCSuccess) {
+                return false;
+            }
+            *outputDataLength += (int)finalMoved;
+        }
+
+        return true;
+    }
+
+    return false;
 #else
     LC_ASSERT(keyLength == 16);
 
@@ -327,6 +427,92 @@ bool PltDecryptMessage(PPLT_CRYPTO_CONTEXT ctx, int algorithm, int flags,
 
     *outputDataLength = outLength;
     return true;
+#elif defined(USE_COMMONCRYPTO)
+    LC_ASSERT(keyLength == 16);
+
+    if (algorithm == ALGORITHM_AES_GCM) {
+        LC_ASSERT(tag != NULL);
+        LC_ASSERT(tagLength > 0);
+
+        // Store key for reuse
+        if (!ctx->initialized) {
+            memcpy(ctx->key, key, keyLength);
+            ctx->keyLength = keyLength;
+            ctx->initialized = true;
