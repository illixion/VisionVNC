+
+    if (algorithm == ALGORITHM_AES_GCM) {
+        LC_ASSERT(tag != NULL);
+        LC_ASSERT(tagLength > 0);
+
+        // Store key for reuse
+        if (!ctx->initialized) {
+            memcpy(ctx->key, key, keyLength);
+            ctx->keyLength = keyLength;
+            ctx->initialized = true;
+        }
+
+        // Use oneshot GCM encryption
+        CCCryptorStatus status = CCCryptorGCMOneshotEncrypt(
+            kCCAlgorithmAES,
+            ctx->key, (size_t)ctx->keyLength,
+            iv, (size_t)ivLength,
+            NULL, 0,
+            inputData, (size_t)inputDataLength,
+            outputData,
+            tag, (size_t)tagLength);
