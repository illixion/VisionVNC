+// MARK: - Framebuffer Update Control
+public extension VNCConnection {
+	/// Pauses automatic framebuffer update requests.
+	/// The connection stays alive for input, but no new frames are requested.
+	func pauseFramebufferUpdates() {
+		state.updatesArePaused = true
+	}
+
+	/// Resumes automatic framebuffer update requests after a pause.
+	func resumeFramebufferUpdates() {
+		state.updatesArePaused = false
+	}
+}
