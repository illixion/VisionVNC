<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>VisionVNC</string>
	<key>CommitHash</key>
	<string>$(COMMIT_HASH)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.illixion.VisionVNCMac.audioToken</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>visionvnc</string>
			</array>
		</dict>
	</array>
	<key>GCSupportedGameControllers</key>
	<array>
		<dict>
			<key>ProfileName</key>
			<string>ExtendedGamepad</string>
		</dict>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>VisionVNC connects to remote desktops, game streaming hosts, and the Companion on your local network.</string>
	<key>NSAudioCaptureUsageDescription</key>
	<string>VisionVNC captures system audio to stream it to the VisionVNC app on your Apple Vision Pro.</string>
	<key>NSAppleEventsUsageDescription</key>
	<string>VisionVNC controls Music and reads the current track so you can see and control playback from your Apple Vision Pro.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
